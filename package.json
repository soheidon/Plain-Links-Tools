{
  "name": "plain-links-tools",
  "version": "0.1.0",
  "description": "Convert Markdown links in the current note to plain text or URLs.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "release:pack": "node scripts/pack-release.cjs"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "links",
    "markdown"
  ],
  "author": "soheidon",
  "license": "MIT",
  "devDependencies": {
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.4",
    "@types/node": "^20.11.30",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.25.0",
    "obsidian": "latest",
    "typescript": "^5.4.5"
  }
}
